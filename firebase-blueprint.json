{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "Entry": {
      "title": "Entry",
      "description": "A mood entry logged by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the entry" },
        "userId": { "type": "string", "description": "The UID of the user who created this entry" },
        "emotionId": { "type": "string", "description": "The ID of the emotion selected" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the entry was created" },
        "note": { "type": "string", "description": "Optional note added to the entry" },
        "photo": { "type": "string", "description": "Optional base64 or URL of a photo" },
        "audio": { "type": "string", "description": "Optional base64 or URL of an audio recording" }
      },
      "required": ["id", "userId", "emotionId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "Entry",
      "description": "Mood entries for a specific user"
    }
  }
}
